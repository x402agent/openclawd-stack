FROM node:22-slim

CLAW_TYPE generic

# Install clawvault globally
RUN npm install -g @versatly/clawvault

# Working directory for benchmark runs
WORKDIR /bench

# Mount fixtures and config from host
VOLUME /bench/fixtures
VOLUME /bench/results

# Entry point runs the benchmark with env-configured provider/model
ENTRYPOINT ["clawvault", "benchmark", "observer", \
  "--fixtures-dir", "/bench/fixtures", \
  "--report-format", "json"]
