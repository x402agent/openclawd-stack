FROM node:22-slim

CLAW_TYPE benchmark
AGENT benchmarks/AGENT.md

# Install ClawVault
RUN npm install -g clawvault@3.2.0

# Install Python for Mem0/competitor comparison
RUN apt-get update && apt-get install -y python3 python3-pip python3-venv git curl && \
    rm -rf /var/lib/apt/lists/*

# Create Python venv for competitor tools
RUN python3 -m venv /opt/bench && \
    /opt/bench/bin/pip install mem0ai letta openai rank_bm25

# Working directory
WORKDIR /bench

# Copy benchmark scripts
COPY benchmarks/ /bench/

# Default: run all benchmarks
CMD ["node", "--loader", "tsx", "/bench/locomo/run.ts"]
