# Gateway-aware kubectl wrapper.
#
# Runs kubectl inside the active gateway's k3s container via
# `openshell doctor exec`.  All arguments are forwarded to kubectl.
#
# Usage:
#   kubectl get pods -A
#   kubectl logs -n openshell statefulset/openshell

exec openshell doctor exec -- kubectl "$@"
