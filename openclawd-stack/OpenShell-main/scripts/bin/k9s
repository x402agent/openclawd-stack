# Gateway-aware k9s wrapper.
#
# Runs k9s inside the active gateway's k3s container via
# `openshell doctor exec`.  All arguments are forwarded to k9s.
#
# Usage:
#   k9s
#   k9s -n openshell

exec openshell doctor exec -- k9s "$@"
