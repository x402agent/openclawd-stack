    "name": "process",
    "description": "The Process object describes a running instance of a launched program.",
    "extends": "process_entity",
    "constraints": {
        "at_least_one": [
            "pid",
            "uid",
            "cpid"
        ]
    },
    "references": [
        {
            "description": "D3FEND\u2122 Ontology d3f:Process",
            "url": "https://d3fend.mitre.org/dao/artifact/d3f:Process/"
        }
    ],
