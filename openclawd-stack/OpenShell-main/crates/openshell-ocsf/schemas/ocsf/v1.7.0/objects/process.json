        },
        {
            "egid": {
                "profile": "linux/linux_users",
                "type": "integer_t",
                "description": "The effective group under which this process is running.",
                "extension": "linux",
                "requirement": "optional",
                "extension_id": 1,
                "caption": "Effective Group ID",
                "type_name": "Integer",
                "_source": "linux/process",
                "_source_patched": "process"
            }
        },
        {
            "euid": {
                "profile": "linux/linux_users",
                "type": "integer_t",
                "description": "The effective user under which this process is running.",
                "extension": "linux",
                "requirement": "optional",
                "extension_id": 1,
                "caption": "Effective User ID",
                "type_name": "Integer",
                "_source": "linux/process",
                "_source_patched": "process"
