# Orchestrator (solanaclawd.com backend) environment.
#
# Every var in the SANDBOX_PASSTHROUGH_ENVS block in
# orchestrator/sandbox-manager.ts is forwarded into each sandbox at launch.
# That includes the Privy full server set (APP_SECRET, AUTH_PRIVATE_KEY),
# Cloudflare Images, and Cloudflare R2. Drop specific names from that list
# if you'd rather keep a given secret orchestrator-only.

# ─── E2B ───────────────────────────────────────────────────────────────────
E2B_API_KEY=e2b_...

# ─── Privy (full server surface — all forwarded to sandbox) ────────────────
PRIVY_APP_ID=...
PRIVY_APP_SECRET=privy_app_secret_...
PRIVY_CLIENT_ID=client-...
PRIVY_JWKS_ENDPOINT=https://auth.privy.io/api/v1/apps/<APP_ID>/jwks.json
PRIVY_AUTH_KEY_ID=...
PRIVY_AUTH_PRIVATE_KEY="wallet-auth:..."           # or full PEM
PRIVY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ─── Honcho v3 ─────────────────────────────────────────────────────────────
HONCHO_URL=https://api.honcho.dev
HONCHO_API_KEY=hch-v3-...

# ─── Solana / Helius ───────────────────────────────────────────────────────
HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=...
# Fallback used for HELIUS_RPC if per-user secret + top-level both miss.
HELIUS_RPC_FALLBACK=https://mainnet.helius-rpc.com/?api-key=
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── Clawd payments ────────────────────────────────────────────────────────
GATEWAY_ORIGIN=https://solanaclawd.com
ORCHESTRATOR_KEEPER_KEY=<base58 Solana secret>     # tx fees only, no funds
CLAWD_VAULT_PROGRAM=<program id from anchor build>
CLAWD_REGISTRY_SEED=clawd-registry-v1
PINATA_JWT=...

# ─── Cloudflare Images (forwarded to sandbox) ──────────────────────────────
HOSTED_IMAGES_ACCOUNT_ID=...
HOSTED_IMAGES_HASH=...
HOSTED_IMAGES_DELIVERY_URL=https://imagedelivery.net/<HASH>/<image_id>/<variant_name>
HOSTED_IMAGES_KEY=...

# ─── Cloudflare R2 (forwarded to sandbox) ──────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_TOKEN_VALUE=...

# ─── Per-user upstream fallbacks (used if Privy Vault lookup misses) ──────
OPENAI_API_KEY_FALLBACK=
ANTHROPIC_API_KEY_FALLBACK=
SOLANA_TRACKER_KEY_FALLBACK=

# ─── Firecrawl (web_scrape / web_search / web_map / web_crawl tools) ──────
FIRECRAWL_API_KEY=fc-...
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# ─── Telegram (orchestrator side) ──────────────────────────────────────────
TELEGRAM_ALLOW_CHAT_IDS=-1003338091119

# ─── Orchestrator HTTP server ──────────────────────────────────────────────
ORCHESTRATOR_PORT=8787
