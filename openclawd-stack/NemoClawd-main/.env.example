# nemoClawd Environment Variables
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# CORE (free at helius.dev)
# ═══════════════════════════════════════════════════════════════════════════════
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}

# ═══════════════════════════════════════════════════════════════════════════════
# xAI Grok (one key unlocks everything)
# ═══════════════════════════════════════════════════════════════════════════════
XAI_API_KEY=                  # Grok: chat, voice, vision, search, multi-agent

# ═══════════════════════════════════════════════════════════════════════════════
# OpenRouter (optional — multi-model LLM routing)
# ═══════════════════════════════════════════════════════════════════════════════
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://github.com/x402agent/NemoClawd
OPENROUTER_SITE_TITLE=nemoClawd
OPENROUTER_CATEGORIES=cli-agent,cloud-agent

# ═══════════════════════════════════════════════════════════════════════════════
# Telegram (from @BotFather)
# ═══════════════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_IDS=     # comma-separated chat IDs (optional)
TELEGRAM_ADMIN_IDS=          # admin user IDs (optional)

# ═══════════════════════════════════════════════════════════════════════════════
# Solana Data (optional — signal-only mode works without)
# ═══════════════════════════════════════════════════════════════════════════════
SOLANA_TRACKER_API_KEY=      # data.solanatracker.io
BIRDEYE_API_KEY=            # Birdeye token data
SOLANA_PUBLIC_KEY=           # Default wallet address
SOLANA_PRIVATE_KEY=         # Base58 keypair (live trades only — BE CAREFUL)

# ═══════════════════════════════════════════════════════════════════════════════
# Vault (AES-256-GCM encrypted secret storage)
# ═══════════════════════════════════════════════════════════════════════════════
VAULT_PASSPHRASE=           # Encryption passphrase

# ═══════════════════════════════════════════════════════════════════════════════
# Deployment
# ═══════════════════════════════════════════════════════════════════════════════
MCP_API_KEY=                # Bearer token for remote MCP server (optional)

# ═══════════════════════════════════════════════════════════════════════════════
# npm Registry (for publishing)
# ═══════════════════════════════════════════════════════════════════════════════
NPM_TOKEN=                   # get from vault or 1password

# ═══════════════════════════════════════════════════════════════════════════════
# Twitter/X (optional — for /tweet, /reply commands)
# ═══════════════════════════════════════════════════════════════════════════════
CONSUMER_KEY=
SECRET_KEY=
ACCESS_TOKEN=
ACCESS_TOKEN_SECRET=
BEARER_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════════
# Pump.fun Sniper (optional)
# ═══════════════════════════════════════════════════════════════════════════════
PUMP_MIN_SCORE=60            # Minimum signal score to trade
BOT_BUY_AMOUNT=0.05         # SOL per buy
BOT_TAKE_PROFIT=50          # TP %
BOT_STOP_LOSS=15           # SL %
BOT_TIMEOUT_SECS=120       # Position timeout
