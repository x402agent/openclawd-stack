# NemoClaw Operations Dashboard — Environment Variables
# Copy to .env and fill in your values

# ─── Server ─────────────────────────────────────────────────
DASHBOARD_PORT=18789
# DASHBOARD_API_KEY=your_api_key_here  # Leave unset for open access

# ─── Bot Service Endpoints (for health polling) ─────────────
# TELEGRAM_BOT_URL=http://localhost:3000
# CHANNEL_BOT_URL=http://localhost:3002
# WEBSOCKET_SERVER_URL=http://localhost:3099

# ─── Credentials (auto-loaded from ~/.nemoclaw/) ────────────
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# TELEGRAM_BOT_TOKEN=your_bot_token
# HELIUS_API_KEY=your_helius_key
# DEVELOPER_WALLET=your_wallet_address

# ─── Inference ──────────────────────────────────────────────
# INFERENCE_MODEL=8bit/DeepSolana
# INFERENCE_PROVIDER=ollama-local
# OLLAMA_URL=http://localhost:11434

# ─── Sandbox ────────────────────────────────────────────────
# SANDBOX_NAME=nemo
