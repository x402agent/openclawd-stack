# ── Lair-TG — Environment Variables ───────────────────────────────
# Copy to .env and fill in values.

# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Required: Solana RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Health check server port
HEALTH_PORT=3000

# Module toggles (true by default, set to "false" to disable)
MODULE_WALLET=true
MODULE_MARKET=true
MODULE_LAUNCH=true
MODULE_ALERTS=true
MODULE_AI=true

# ── AI Configuration ─────────────────────────────────────────────
# OpenRouter API key (enables AI assistant and DeFi agents)
OPENROUTER_API_KEY=

# AI model to use (default: Grok 4)
OPENROUTER_MODEL=x-ai/grok-4-0820

# DeFi Agents API URL (default: sperax.click)
DEFI_AGENTS_URL=https://sperax.click/index.json
