## Docker Compose (Local Development)

Run the full bot fleet locally for development and testing:

```yaml
# docker-compose.yml (place in repo root)
version: "3.8"

services:
  telegram-bot:
    build: ./telegram-bot
    restart: unless-stopped
    ports:
      - "3000:3000"
    env_file: ./telegram-bot/.env
    volumes:
      - telegram-data:/app/data

  channel-bot:
    build: ./channel-bot
    restart: unless-stopped
    ports:
      - "3002:3000"
    env_file: ./channel-bot/.env
    volumes:
      - channel-data:/app/data

  claim-bot:
    build: ./claim-bot
    restart: unless-stopped
    env_file: ./claim-bot/.env
    volumes:
      - claim-data:/app/data

  websocket-server:
    build: ./websocket-server
    restart: unless-stopped
    ports:
      - "3099:3099"
    env_file: ./websocket-server/.env

  swarm-bot:
    build:
      context: .
      dockerfile: swarm-bot/Dockerfile
    restart: unless-stopped
    ports:
      - "3100:3100"
    env_file: ./swarm-bot/.env
    volumes:
      - swarm-data:/app/data

  dashboard:
    build: ./dashboard
    restart: unless-stopped
    ports:
      - "8080:8080"
    env_file: ./dashboard/.env
    depends_on:
      - telegram-bot
      - channel-bot
      - websocket-server
    environment:
      - TELEGRAM_BOT_URL=http://telegram-bot:3000
      - CHANNEL_BOT_URL=http://channel-bot:3000
      - WEBSOCKET_SERVER_URL=http://websocket-server:3099

volumes:
  telegram-data:
  channel-data:
  claim-data:
  swarm-data:
```

```bash
# Start all services
docker compose up -d

# View logs
docker compose logs -f telegram-bot

# Stop all services
docker compose down
```

> **Note:** The `outsiders-bot` is excluded from Docker Compose because it requires native `canvas` libraries. Run it separately with `npm run dev` in its directory.

