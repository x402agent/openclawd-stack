# Outsiders Bot — Environment Variables
# Copy to .env and fill in your values

# Required — Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional — Forward calls to a dedicated channel (numeric ID, e.g. -1001234567890)
# CALL_CHANNEL_ID=-1001234567890

# Optional — DexScreener API base (default shown)
DEXSCREENER_API=https://api.dexscreener.com

# Optional — ATH polling interval in seconds (default: 60)
ATH_POLL_INTERVAL=60

# Optional — Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Optional — SQLite database path (default: ./outsiders.db)
DB_PATH=./outsiders.db
