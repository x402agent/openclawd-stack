{
  "name": "@pump-fun/random-number-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Payment-gated random number generator using Pump Tokenized Agent Payments SDK",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "bot": "tsx src/bot/index.ts",
